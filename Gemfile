source "https://rubygems.org"

# Local build tooling (GitHub Pages uses its own build environment).
#
# Pinned to Jekyll 4.2.x for compatibility with older Sass pipeline;
# newer Jekyll versions use `sass-embedded`, which can be finicky in containers.
gem "jekyll", "4.4.1"
gem "jekyll-sass-converter", "~> 2.2"
gem "sassc"
gem "jekyll-remote-theme"
gem "jekyll-redirect-from"
gem "jekyll-sitemap"
gem "jekyll-feed"
gem "jekyll-seo-tag"
gem "csv"
gem "base64"
gem "bigdecimal"

# Required for `jekyll serve` on Ruby 3+.
gem "webrick"
